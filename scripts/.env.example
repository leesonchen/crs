# 账户管理测试配置文件
# 复制此文件为 .env 并填入实际值

# 服务配置
TEST_BASE_URL=http://localhost:3000
TEST_TIMEOUT=30000
TEST_MAX_RETRIES=3
TEST_RETRY_DELAY=1000

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password
ADMIN_TOKEN=

# API Key 配置
TEST_API_KEY=cr_your_test_api_key
TEST_API_DAILY_QUOTA=1000
TEST_API_HOURLY_QUOTA=100

# 输出配置
TEST_REPORT_DIR=./test-reports
TEST_VERBOSE=false
TEST_JSON_OUTPUT=true
TEST_SAVE_LOGS=true
TEST_LOG_LEVEL=info

# 账户测试选项
TEST_VERIFY_SSL=true
TEST_USE_PROXY=false

# 代理配置 (如果需要)
# TEST_PROXY_HOST=
# TEST_PROXY_PORT=8080
# TEST_PROXY_PROTOCOL=http
# TEST_PROXY_USERNAME=
# TEST_PROXY_PASSWORD=